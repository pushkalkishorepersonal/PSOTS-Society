# ─── PSOTS Community Portal — environment variables ──────────────────────────
# Copy to .env and fill in your values.

# PostgreSQL — required. Local example below; use Neon/Supabase for production.
DATABASE_URL=postgresql://psots_dev:psots_dev@localhost:5432/psots_dev

# Express API port (default 4000 when not set)
PORT=4000

# Vite proxy forwards /api/* to this port in dev mode (must match PORT)
API_PORT=4000

# Telegram bot token — create a bot at https://t.me/BotFather
# Leave empty to disable the bot in local dev
TELEGRAM_BOT_TOKEN=

# Community PIN residents enter to post notices (default: PSOTS2025)
COMMUNITY_PIN=PSOTS2025
